{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PixForge",
  "version": "1.0.0",
  "identifier": "DF1049EA.PixForge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PixForge",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "唐昆",
    "copyright": "Copyright © 2025 唐昆. All rights reserved.",
    "category": "Graphics and Design",
    "resources": {
      "models/silueta.onnx": "models/silueta.onnx"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese"],
        "compression": "lzma",
        "displayLanguageSelector": true
      }
    }
  }
}
